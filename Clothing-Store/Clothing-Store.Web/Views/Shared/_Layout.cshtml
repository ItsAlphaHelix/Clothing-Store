<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Clothing_Store</title>
    @* <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /> *@
    <link rel="stylesheet" href="~/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/font-awesome.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/slick.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/slick-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/mg-animations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/mg-menu.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/jquery.highlight.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/magnific-popup.css" asp-append-version="true" />

    <partial name="_ValidationScriptsPartial" />
</head>
<body class="home-2">

    @if (this.ViewBag.IsHomePage)
    {
        <header class="mg-transparent-header">
            <partial name="_NavigationHomePartial.cshtml" />
        </header>
    }
    else
    {
        <header>
            <partial name="_GlobalNavigationPartial.cshtml" />
        </header>
    }
    <div class="modal fade mg-account-modal-outer" id="account-modal" tabindex="-1" aria-labelledby="account-modal" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
        </div>
    </div>
    <main role="main">
        @RenderBody()
    </main>

    @* <footer class="border-top footer text-muted">
    <div class="container">
    &copy; 2024 - Clothing_Store - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
    </footer> *@

    <script src="~/js/jquery.min.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/bootstrap.min.js" asp-append-version="true"></script>
    <script src="~/js/account.js" asp-append-version="true"></script>
    @* <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script> *@
    <script src="~/js/popper.min.js" asp-append-version="true"></script>
    <script src="~/js/jquery.magnific-popup.js" asp-append-version="true"></script>
    <script src="~/js/jquery.highlight.js" asp-append-version="true"></script>
    <script src="~/js/gen_validatorv4.js" asp-append-version="true"></script>
    <script src="~/js/slick.js" asp-append-version="true"></script>
    <script src="~/js/mg-menu.js" asp-append-version="true"></script>
    <script src="~/js/mg-product.js" asp-append-version="true"></script>
     <script src="~/js/mg-collection.js" asp-append-version="true"></script>
    <script src="~/js/mg-common.js" asp-append-version="true"></script>
    <script>
        var currentUrl = window.location.href;
        var pathSegments = currentUrl.split('/');
        var action = pathSegments.pop()
        $(document).ready(function () {
            $('.page-link').click(function (e) {
                e.preventDefault();
                var page = $(this).data('page');
                var currentPage = parseInt($('.pagination .page-item .page-link.active').data('page'));
                if (page === "previouse") {
                    page = Math.max(1, currentPage - 1);
                } else if (page === "next") {
                    var totalPages = @Model.Products.TotalPages;
                    page = Math.min(totalPages, currentPage + 1);
                } else {
                    page = parseInt(page, 10);
                }

                
                var ajaxUrl = "/Products/" + action;
                $.ajax({
                    url: ajaxUrl,
                    type: 'GET',
                    data: { page: page },
                    success: function (result) {
                        $('#products-container').html(result);
                        //console.log($('.pagination .page-item .page-link'))
                        $('.pagination .page-item .page-link').removeClass('active');

                        $('.pagination .page-item a[data-page="' + page + '"]').addClass('active');
                    }
                });
            });
        });

        $('.filter-link').on('click', function (e) {
            e.preventDefault(); // Prevent the default anchor click behavior

            // Toggle an 'active' class to indicate selection
            $(this).toggleClass('active');

            // Get all active queries
            var selectedQueries = $('.filter-link.active').map(function () {
                return $(this).data('query');
            }).get();

            $.ajax({
                url: '@Url.Action("FilterProducts", "Search")',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                data: {
                    queries: selectedQueries
                },
                success: function (result) {
                    if (result.products.length === 0) {
                        location.reload();
                    }
                    var productsHtml = '<div class="mg-collection-product-list-outer"><div class="row">';

                    result.products.forEach(function (product) {
                        productsHtml += `
                                        <div class="col-md-4 col-sm-6">
                                            <div class="mg-product-main mg-img-hdark">
                                                <div class="position-relative">
                                                    <div class="mg-product-image">
                                                        <a href="/Products/ProductDetails/${product.id}">
                                                            <img class="img-fluid" src="${product.images[0]}" alt="" />
                                                        </a>
                                                        <a href="/Products/ProductDetails/${product.id}">
                                                            <img class="img-fluid mg-hover-img" src="${product.images[1]}" alt="" />
                                                        </a>
                                                    </div>
                                                    <div class="mg-product-icons-outer">
                                                        <div class="mg-product-icon">
                                                            <a href="#"><img class="mg-product-icon-img" src="/images/svgs/heart-icon.svg" alt="" /></a>
                                                        </div>
                                                        <div class="mg-product-icon">
                                                            <a href="javascript:void(0)" onclick="loadProductDetails(${product.id})">
                                                                <img class="mg-product-icon-img" src="/images/svgs/view-icon.svg" alt="" />
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <div class="mg-product-add-to-cart-btn-outer">
                                                        <a class="mg-product-add-to-cart-btn" href="cart.html">Add To Bag</a>
                                                    </div>
                                                </div>
                                                <div class="mg-product-tittles text-center">
                                                    <a class="mg-product-name" href="/Products/ProductDetails/${product.id}">${product.category}</a>
                                                    <div class="mg-regular-price">
                                                        <span class="mg-discount-price"></span>${product.price} BGN
                                                    </div>
                                                </div>
                                            </div>
                                        </div>`;
                    });

                    $("#products-container").html(productsHtml);
                    console.log(result);
                    console.log(result);

                    if (result.totalPages == 1) {
                        $('.mg-pagination-outer').hide();
                        return;
                    }
                    $('.mg-pagination-outer').show();
                    let paginationHtml = '<li class="page-item pagination-nextprev">' +
                        '<a class="page-link" data-page="previous" aria-label="Previous">' +
                        '<img src="/images/mg-arrow-left.png" alt="" />' +
                        '</a></li>';

                    for (let i = 1; i <= result.totalPages; i++) {
                        let activeClass = (i === result.page) ? 'active' : '';
                        paginationHtml += `<li class="page-item">` +
                            `<a class="page-link ${activeClass}" data-page="${i}" href="#">${i}</a>` +
                            `</li>`;
                    }

                    paginationHtml += '<li class="page-item pagination-nextprev">' +
                        '<a class="page-link" data-page="next" aria-label="Next">' +
                        '<img src="/images/mg-arrow-right.png" alt="" />' +
                        '</a></li>';
                    console.log($('.mg-pagination-outer'))
                    $('.pagination').html(paginationHtml)
                    let = result = `<nav id="nav-pagination"><ul class="pagination justify-content-center align-items-center">${paginationHtml}</ul></nav>`

                    $('.mg-pagination-outer').html(result);

                    $(document).ready(function () {
                        $('.page-link').click(function (e) {
                            e.preventDefault();
                            console.log(e.target)
                            var page = $(this).data('page');
                            var currentPage = parseInt($('.pagination .page-item.active a').data('page'), 10);

                            if (page === "prev") {
                                page = Math.max(1, currentPage - 1);
                            } else if (page === "next") {
                                var totalPages = @Model.Products.TotalPages;
                                page = Math.min(totalPages, currentPage + 1);
                            } else {
                                page = parseInt(page, 10);
                            }


                            $.ajax({
                                url: '@Url.Action("FilterProducts", "Search")',
                                type: 'POST',
                                contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                                data: {
                                    queries: selectedQueries,
                                    page: page
                                },
                                success: function (result) {
                                    var productsHtml = '<div class="mg-collection-product-list-outer"><div class="row">';

                                    result.products.forEach(function (product) {
                                        productsHtml += `
                                                                        <div class="col-md-4 col-sm-6">
                                                                            <div class="mg-product-main mg-img-hdark">
                                                                                <div class="position-relative">
                                                                                    <div class="mg-product-image">
                                                                                        <a href="/Products/ProductDetails/${product.id}">
                                                                                            <img class="img-fluid" src="${product.images[0]}" alt="" />
                                                                                        </a>
                                                                                        <a href="/Products/ProductDetails/${product.id}">
                                                                                            <img class="img-fluid mg-hover-img" src="${product.images[1]}" alt="" />
                                                                                        </a>
                                                                                    </div>
                                                                                    <div class="mg-product-icons-outer">
                                                                                        <div class="mg-product-icon">
                                                                                            <a href="#"><img class="mg-product-icon-img" src="/images/svgs/heart-icon.svg" alt="" /></a>
                                                                                        </div>
                                                                                        <div class="mg-product-icon">
                                                                                            <a href="javascript:void(0)" onclick="loadProductDetails(${product.id})">
                                                                                                <img class="mg-product-icon-img" src="/images/svgs/view-icon.svg" alt="" />
                                                                                            </a>
                                                                                        </div>
                                                                                    </div>
                                                                                    <div class="mg-product-add-to-cart-btn-outer">
                                                                                        <a class="mg-product-add-to-cart-btn" href="cart.html">Add To Bag</a>
                                                                                    </div>
                                                                                </div>
                                                                                <div class="mg-product-tittles text-center">
                                                                                    <a class="mg-product-name" href="/Products/ProductDetails/${product.id}">${product.category}</a>
                                                                                    <div class="mg-regular-price">
                                                                                        <span class="mg-discount-price"></span>${product.price} BGN
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </div>`;
                                    });

                                    $("#products-container").html(productsHtml);
                                    $('.pagination .page-item .page-link').removeClass('active');
                                    $('.pagination .page-item a[data-page="' + page + '"]').addClass('active');
                                }
                            });
                        });
                    });
                },
                error: function () {
                    console.log('An error occurred while retrieving filtered product data.');
                }

            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
