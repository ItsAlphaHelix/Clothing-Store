                    <div class="mg-collection-grid-pannel mt-5">
                        <div class="mg-section-tittles text-center">
                            <h2 class="mg-heading mg-heading-small">@this.ViewData["Title"]</h2>
                        </div>
                        <div class="mg-sorting-outer mb-3">
                            <!--Select Input Sorting-->
                            <form>
                                <div class="mg-sorting">
                                    <label>Shorted By:</label>
                                    <select class="form-control">
                                        <option value="default" selected="selected">Featured</option>
                                        <option value="popularity">Popularity</option>
                                        <option value="rating">Average Rating</option>
                                        <option value="date">Latest</option>
                                        <option value="price-low">Low To High</option>
                                        <option value="price-high">High To Low</option>
                                    </select>
                                </div>
                            </form>
                            <!--Select Input Sorting-->
                            <!--HTML Sorting-->
                            <div class="mg-html-sorting-outer d-none">
                                <div class="mg-html-sorting-bar">Shorted By: <span class="mg-sorting-selected">Featured</span></div>
                                <div class="mg-html-sorting-options-pannel">
                                    <ul>
                                        <li class="selected"><a href="#">Featured</a></li>
                                        <li><a href="javascript:void(0);">Popularity</a></li>
                                        <li><a href="javascript:void(0);">Average Rating</a></li>
                                        <li><a href="javascript:void(0);">Latest</a></li>
                                        <li><a href="javascript:void(0);">Low To High</a></li>
                                        <li><a href="javascript:void(0);">High To Low</a></li>
                                    </ul>
                                </div>
                            </div>
                            <!--HTML Sorting-->
                            <span class="d-md-none mg-filter-nav-btn"><i class="fa fa-filter" aria-hidden="true"></i> Filters</span>
                        </div>
                        <!--Products Grid Start Here-->
                        <div>
                            <div class="mg-collection-product-list-outer">
                                <div class="row">
                                    @foreach (var product in Model)
                                    {
                                        <div class="col-md-4 col-sm-6">
                                            <div class="mg-product-main mg-img-hdark">
                                                <div class="position-relative">
                                                    <div class="mg-product-image">
                                                        <a asp-controller="Products" asp-action="ProductDetails" asp-route-id="@product.Id"><img class="img-fluid" src="@product.Images[0]" alt="" /></a>
                                                        <a asp-controller="Products" asp-action="ProductDetails" asp-route-id="@product.Id"><img class="img-fluid mg-hover-img" src="@product.Images[1]" alt="" /></a>
                                                    </div>
                                                    <div class="mg-product-icons-outer">
                                                        <div class="mg-product-icon">
                                                            <a href="#"><img class="mg-product-icon-img" src="~/images/svgs/heart-icon.svg" alt="" /></a>
                                                        </div>
                                                        <div class="mg-product-icon">
                                                            <a href="javascript:void(0)" onclick="loadProductDetails(@product.Id)"><img class="mg-product-icon-img" src="~/images/svgs/view-icon.svg" alt="" /></a>
                                                        </div>
                                                    </div>
                                                    <div class="mg-product-add-to-cart-btn-outer">
                                                        <a class="mg-product-add-to-cart-btn" href="cart.html">Add To Bag</a>
                                                    </div>
                                                </div>
                                                <div class="mg-product-tittles text-center">
                                                    <a class="mg-product-name" href="product.html">@product.Category</a>
                                                    <div class="mg-regular-price"><span class="mg-discount-price"></span>@product.Price BGN</div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        <!--Products Grid End Here-->
                        <!--MG Pagination Start Here-->
                        <div class="mg-pagination-outer mt-3">
                            <nav>
                                <ul class="pagination justify-content-center align-items-center">
                                    <li class="page-item pagination-nextprev">
                                        <a class="page-link" href="#" aria-label="Previous">
                                            <img src="assets/images/mg-arrow-left.png" alt="" />
                                        </a>
                                    </li>
                                    <li class="page-item"><a class="page-link active" href="#">1</a></li>
                                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                                    <li class="page-item pagination-nextprev">
                                        <a class="page-link" href="#" aria-label="Next">
                                            <img src="assets/images/mg-arrow-right.png" alt="" />
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                        <!--MG Pagination End Here-->
                    </div>
                </div>
            </div>
