@using Clothing_Store.Controllers;
@model CategoryProductViewModel

<div id="tab1" class="accordion-collapse collapse show">
    <div class="accordion-body">
        <div class="mg-filter-panel">
            <div class="mg-filter-checkbox">
                <ul>
                    <li><a class="filter-link" data-query="Пуловер">Пуловери</a></li>
                    <li><a class="filter-link" data-query="Тениска">Тениски</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div id="products">
    <h2>Products</h2>
    <ul id="product-list">
        @foreach (var product in Model.Products)
        {
            <li>@product.Name - @product.Price</li>
        }
    </ul>
</div>

<nav id="nav-pagination">
    <ul class="pagination">
        <li class="page-item"><a class="page-link" data-page="prev" href="#">Previous</a></li>
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(Model.CurrentPage == i ? "active" : "")"><a class="page-link" data-page="@i" href="#">@i</a></li>
        }
        <li class="page-item"><a class="page-link" data-page="next" href="#">Next</a></li>
    </ul>
</nav>

@section Scripts {
    <script>

        $(document).ready(function () {
            $('.page-link').click(function (e) {
                e.preventDefault();
                var page = $(this).data('page');
                var currentPage = parseInt($('.pagination .page-item.active a').data('page'), 10);

                if (page === "prev") {
                    page = Math.max(1, currentPage - 1);
                } else if (page === "next") {
                    var totalPages = @Model.TotalPages;
                    page = Math.min(totalPages, currentPage + 1);
                } else {
                    page = parseInt(page, 10);
                }


                $.ajax({
                    url: '@Url.Action("Test", "Products")',
                    type: 'GET',
                    data: { page: page },
                    success: function (result) {
                        $('#product-list').html(result);
                        $('.pagination .page-item').removeClass('active');
                        $('.pagination .page-item a[data-page="' + page + '"]').parent().addClass('active');
                        console.log($('.pagination .page-item a[data-page="' + page + '"]'))
                    }
                });
            });
        });


        // Listen for click events on .filter-link elements
        $('.filter-link').on('click', function (e) {
            e.preventDefault(); // Prevent the default anchor click behavior

            // Toggle an 'active' class to indicate selection
            $(this).toggleClass('active');

            // Get all active queries
            var selectedQueries = $('.filter-link.active').map(function () {
                return $(this).data('query');
            }).get();

            console.log(selectedQueries);
            // Send AJAX request to retrieve filtered product data
            $.ajax({
                url: '@Url.Action("FilterTestProducts", "Products")',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                data: {
                    queries: selectedQueries,
                },
                success: function (result) {
                    if (result.products.length === 0) {
                        location.reload();
                    }
                    let productsHtml = '<h2>Products</h2><ul id="product-list">';
                    result.products.forEach(function (product) {
                        productsHtml += `<li>${product.name} - ${product.price}</li>`;
                    });
                    productsHtml += '</ul>';

                    $('#products').html(productsHtml);

                    let paginationHtml = '<li class="page-item"><a class="page-link" data-page="prev" href="#">Previous</a></li>';
                    for (let i = 1; i <= result.totalPages; i++) {
                        let activeClass = (i === result.currentPage) ? 'active' : '';
                        paginationHtml += `<li class="page-item ${activeClass}"><a class="page-link" data-page="${i}" href="#">${i}</a></li>`;
                    }
                    paginationHtml += '<li class="page-item"><a class="page-link" data-page="next" href="#">Next</a></li>';

                    $('#nav-pagination .pagination').html(paginationHtml);



                    $(document).ready(function () {
                            $('.page-link').click(function (e) {
                                e.preventDefault();
                                console.log(e.target)
                                var page = $(this).data('page');
                                var currentPage = parseInt($('.pagination .page-item.active a').data('page'), 10);

                                if (page === "prev") {
                                    page = Math.max(1, currentPage - 1);
                                } else if (page === "next") {
                                    var totalPages = @Model.TotalPages;
                                    page = Math.min(totalPages, currentPage + 1);
                                } else {
                                    page = parseInt(page, 10);
                                }


                                $.ajax({
                                    url: '@Url.Action("FilterTestProducts", "Products")',
                                    type: 'POST',
                                    contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                                    data: {
                                        queries: selectedQueries,
                                        page: page
                                    },
                                    success: function (result) {
                                    console.log(result);
                                    let productsHtml = '<h2>Products</h2><ul id="product-list">';
                                    result.products.forEach(function (product) {
                                        productsHtml += `<li>${product.name} - ${product.price}</li>`;
                                    });
                                    productsHtml += '</ul>';

                                    $('#products').html(productsHtml);
                                       $('.pagination .page-item').removeClass('active');
                                       $('.pagination .page-item a[data-page="' + result.currentPage + '"]').parent().addClass('active');
                                    }
                                });
                            });
                        });
                },
                error: function () {
                    console.log('An error occurred while retrieving filtered product data.');
                }
            });
        });

    </script>
}