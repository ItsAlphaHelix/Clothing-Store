                    }
                }
            });
        }
        function displayErrorMessage(message, elementId) {
            var errorMessageElement = $('#' + elementId);
            errorMessageElement.text(message);
        }

        function clearErrorMessage(elementId) {
            var errorMessageElement = $('#' + elementId);
            errorMessageElement.text('');
        }
    </script>
}
